@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav

<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly" AdditionalAssemblies="new[] { typeof(Client._Imports).Assembly }">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Client.Layout.MainLayout)">
                <NotAuthorized>
                    @{
                        var current = Nav.ToBaseRelativePath(Nav.Uri);
                        if (!current.StartsWith("login", StringComparison.OrdinalIgnoreCase))
                        {
                            var requiresAuth = routeData.PageType
                            .GetCustomAttributes(typeof(AuthorizeAttribute), inherit: true).Any();

                            if (requiresAuth)
                            {
                                var ru = "/" + current.TrimStart('/');
                                Nav.NavigateTo($"login?returnUrl={Uri.EscapeDataString(ru)}", forceLoad: true);
                            }
                        }
                    }
                    <p>You're being redirected to the login page. Please wait a moment.</p>
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>

        <NotFound>
            <LayoutView Layout="@typeof(Client.Layout.MainLayout)">
                <div class="d-flex flex-column align-items-center justify-content-center text-center" style="height: 82vh">
                    <div class="mb-4">
                        <i class="fa-solid fa-file-circle-exclamation text-secondary" style="font-size: 6rem; opacity: 0.5;"></i>
                    </div>

                    <h1 class="display-1 fw-bold text-primary">404</h1>
                    <h3 class="mb-3">Oops! Page Not Found</h3>
                    <p class="text-muted mb-4">
                        Sorry, the page you are looking for doesn't exist or has been moved.
                    </p>

                    <a href="/" class="btn btn-primary btn-lg px-5 shadow-sm">
                        <i class="fa-solid fa-house me-2"></i> Back to Home
                    </a>
                </div>
            </LayoutView>
        </NotFound>

    </Router>
</CascadingAuthenticationState>