<div class="modal fade show d-block" style="background: rgba(0,0,0,0.4); backdrop-filter: blur(8px);" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-2xl overflow-hidden" style="border-radius: 24px;">
            <div class="modal-body p-0">
                <div class="p-4 text-center bg-light border-bottom">
                    <div class="mb-3">
                        <i class="fa-solid fa-language fa-3x text-danger opacity-75"></i>
                    </div>
                    <p class="text-muted small mb-0">โปรดเลือกภาษาเพื่อเริ่มต้นใช้งาน</p>
                </div>

                <div class="p-4 bg-white">
                    <div class="d-grid gap-3">
                        <button class="btn lang-card d-flex align-items-center justify-content-between p-3" @onclick='() => SelectLanguage("th")'>
                            <div class="d-flex align-items-center">
                                <span class="flag-icon me-3">🇹🇭</span>
                                <div class="text-start">
                                    <div class="fw-bold text-dark">ภาษาไทย</div>
                                    <div class="small text-muted">Thai Language</div>
                                </div>
                            </div>
                            <i class="fa-solid fa-chevron-right text-muted"></i>
                        </button>

                        <button class="btn lang-card d-flex align-items-center justify-content-between p-3" @onclick='() => SelectLanguage("en")'>
                            <div class="d-flex align-items-center">
                                <span class="flag-icon me-3">🇺🇸</span>
                                <div class="text-start">
                                    <div class="fw-bold text-dark">English</div>
                                    <div class="small text-muted">English Language</div>
                                </div>
                            </div>
                            <i class="fa-solid fa-chevron-right text-muted"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<bool> OnClose { get; set; }

    private void SelectLanguage(string lang)
    {
        _ = JS.InvokeVoidAsync("localStorage.setItem", "userLanguageSelected", "true");

        var pathAndQuery = new Uri(Nav.Uri).GetComponents(UriComponents.PathAndQuery, UriFormat.Unescaped);
        var cultureEscaped = Uri.EscapeDataString(lang);
        var uriEscaped = Uri.EscapeDataString(pathAndQuery);

        Nav.NavigateTo($"culture/Set?culture={cultureEscaped}&redirectUri={uriEscaped}", forceLoad: true);

        OnClose.InvokeAsync();

        StateHasChanged();
    }
}