@layout Layout.LandingLayout
@page "/"

<PageTitle>TALK TO ME</PageTitle>

@* --- Main Content --- *@
<div class="row justify-content-center align-items-center @(showLanguageModal ? "d-none" : "")">
    <div class="col-md-10 col-lg-7 col-xl-8">
        <div class="card border-0 shadow-2xl" style="border-radius: 24px; background: #ffffff;">

            @* Header Section *@
            <div class="p-5 text-center border-bottom" style="background: linear-gradient(to bottom, #fff5f5 0%, #ffffff 100%); border-radius: 24px 24px 0 0;">
                <h2 class="fw-extrabold mb-2" style="letter-spacing: -1px; color: #991b1b;">
                    @L["SubmitComplaint"]
                </h2>

                <div class="d-flex justify-content-center">
                    <p class="text-muted mb-0 px-3 py-1" style="background: #fef2f2; border-radius: 8px; font-size: 0.9rem; color: #b91c1c !important;">
                        <i class="bi bi-info-circle-fill me-1"></i>
                        @L["VerificationHint"]
                    </p>
                </div>
            </div>

            @* Form Section *@
            <div class="card-body p-4 p-md-5">
                <form @onsubmit="OnSubmit">
                    <div class="mb-4">
                        <label class="form-label fw-semibold text-dark small mb-2 text-uppercase">
                            @L["Subject"]
                        </label>
                        <input type="text" class="form-control form-control-lg custom-input" @bind="complaint.Title" placeholder='@L["TitleEx"]' required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold text-dark small mb-2 text-uppercase">
                            @L["DescHint"]
                        </label>
                        <textarea class="form-control custom-input" rows="5" @bind="complaint.Description" placeholder='@L["ProvDetail"]' required></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold text-dark small mb-2 text-uppercase">
                            @L["PicOpt"]
                        </label>
                        <div class="upload-area">
                            <InputFile OnChange="HandleFileSelected" multiple style="display: none;" id="fileUpload" />
                            <label for="fileUpload" class="upload-label text-muted" style="cursor: pointer; border: 2px dashed #dee2e6; padding: 2rem; display: block; text-align: center; border-radius: 12px;">
                                <i class="bi bi-images fs-2 d-block mb-2 text-danger"></i>
                                <span class="small fw-bold text-dark">
                                    @L["SelectImages"]
                                </span>
                            </label>
                        </div>

                        @if (selectedFiles.Any())
                        {
                            <div class="mt-3 p-3 bg-light rounded-3 border">
                                <div class="small fw-bold mb-2 text-secondary text-uppercase" style="font-size: 0.7rem;">
                                    @L["SelectedFiles"]
                                </div>
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var file in selectedFiles)
                                    {
                                        <div class="d-flex align-items-center justify-content-between bg-white p-2 rounded-2 border-sm shadow-sm">
                                            <div class="d-flex align-items-center overflow-hidden">
                                                <i class="bi bi-file-earmark-image text-danger me-2"></i>
                                                <span class="text-truncate small">@file.Name</span>
                                            </div>
                                            <i class="i-btn-icon text-danger fa-solid fa-trash" @onclick="() => RemoveFile(file)"></i>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <button type="submit" class="btn btn-danger btn-lg w-100 py-3 fw-bold mt-2 shadow-danger">
                        @L["SubmitReport"] <i class="bi bi-arrow-right-short ms-2"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@* --- Language Selection Modal --- *@
@if (showLanguageModal)
{
    <LanguageSelection OnClose="CloseModal" />
}

@code {
    private Complaint complaint = new();
    private List<IBrowserFile> selectedFiles = new();

    private bool showLanguageModal = false;
    private bool isLoading = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var langSelected = await JS.InvokeAsync<string>("localStorage.getItem", "userLanguageSelected");

                if (string.IsNullOrEmpty(langSelected))
                {
                    showLanguageModal = true;
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                LogError("OnAfterRenderAsync", ex.Message);
            }
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles();
        foreach (var file in files)
        {
            if (!selectedFiles.Any(f => f.Name == file.Name && f.Size == file.Size))
            {
                selectedFiles.Add(file);
            }
        }
        StateHasChanged();
    }

    private void RemoveFile(IBrowserFile file)
    {
        selectedFiles.Remove(file);
        StateHasChanged();
    }

    private void CloseModal()
    {
        showLanguageModal = false;
    }

    /* ========== Action ========== */

    private async Task OnSubmit()
    {
        await ShowLoading(async () =>
        {
            var uploadModels = new List<FileUploadModel>();

            foreach (var file in selectedFiles)
            {
                uploadModels.Add(new FileUploadModel
                {
                    FileName = file.Name,
                    Size = file.Size,
                    FileStream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 15)
                });
            }

            complaint.AttachmentsCount = uploadModels.Count;

            bool ok = await ComplaintService.CreateComplaintAsync(complaint, uploadModels);
            if (ok)
            {
                foreach (var upload in uploadModels)
                {
                    upload.FileStream?.Dispose();
                }

                await ActivityLog("OnSubmit", $"Success: Complaint '{complaint.Title}' submitted with {uploadModels.Count} files.");

                ToastService.ShowSuccess(L["ComplaintSubmitted"]);

                complaint = new Complaint();
                selectedFiles.Clear();
            }
            else
            {
                LogError("OnSubmit", $"Failure: Could not submit '{complaint.Title}'. Service returned error.");

                ToastService.ShowError(L["ErrComplaintSubmission"]);
            }
        });
    }

    /* ========== Loading ========== */

    private async Task ShowLoading(Func<Task> work)
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            await work();
        }
        catch (Exception ex)
        {
            LogError("ShowLoading", ex.Message);
            ToastService.ShowError(L["ErrUnexpected"]);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    /* ========== Log ========== */

    private void LogError(string fn, string msg) => LoggerHelper.WriteLog($"Home -> {fn}", msg);

    private async Task ActivityLog(string fn, string msg)
    {
        try
        {
            await ActivityLogService.WriteLogAsync("-", $"Home -> {fn}", msg);
        }
        catch (Exception ex)
        {
            LogError("ActivityLog", ex.Message);
        }
    }
}